<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BuoyCalc.Windows.Views.MainWindow"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="720"
        Background="#F3F6FA"
        Title="BuoyCalc Windows v0.2">

  <Grid RowDefinitions="Auto,*">

    <!-- Header -->
    <Border Grid.Row="0" Background="#172033" Padding="20,16">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="BuoyCalc Windows"
                     FontSize="26"
                     FontWeight="Bold"
                     Foreground="White" />
          <TextBlock Text="Предварительный инженерный расчёт буйковой постановки"
                     FontSize="13"
                     Foreground="#C7D2E5" />
        </StackPanel>

        <Border Grid.Column="1"
                Background="#263653"
                CornerRadius="12"
                Padding="14,8"
                VerticalAlignment="Center">
          <TextBlock Text="v0.2 UI preview"
                     Foreground="#C7D2E5"
                     FontSize="13" />
        </Border>
      </Grid>
    </Border>

    <!-- Main content -->
    <Grid Grid.Row="1"
          ColumnDefinitions="360,*,360"
          ColumnSpacing="16"
          Margin="18">

      <!-- Left panel -->
      <ScrollViewer Grid.Column="0">
        <StackPanel Spacing="14">

          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <StackPanel Spacing="10">
              <TextBlock Text="Проект" FontSize="18" FontWeight="Bold" />
              <TextBlock Text="Название и исходная настройка расчёта" FontSize="12" Foreground="#697386" />
              <TextBox Text="{Binding ProjectName}" Watermark="Название проекта" />
            </StackPanel>
          </Border>

          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <StackPanel Spacing="10">
              <TextBlock Text="Условия постановки" FontSize="18" FontWeight="Bold" />
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="Плотность воды, кг/м³" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding WaterDensity}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Глубина, м" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding Depth}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="4">
                  <TextBlock Text="Течение, м/с" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding CurrentSpeed}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                  <TextBlock Text="Высота волны, м" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding WaveHeight}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="4">
                  <TextBlock Text="Период волны, с" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding WavePeriod}" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <StackPanel Spacing="10">
              <TextBlock Text="Буй" FontSize="18" FontWeight="Bold" />
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="Объём, м³" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding BuoyVolume}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Масса, кг" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding BuoyWeight}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="4">
                  <TextBlock Text="Площадь, м²" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding BuoyArea}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                  <TextBlock Text="Cd" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding BuoyCd}" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <StackPanel Spacing="10">
              <TextBlock Text="Якорь и запас" FontSize="18" FontWeight="Bold" />
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="Масса, кг" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding AnchorWeight}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Объём, м³" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding AnchorVolume}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="4">
                  <TextBlock Text="Коэф. удержания" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding AnchorCoefficient}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                  <TextBlock Text="Коэф. запаса" FontSize="12" Foreground="#697386" />
                  <TextBox Text="{Binding SafetyFactor}" />
                </StackPanel>
              </Grid>

              <Button Content="Рассчитать систему"
                      Command="{Binding CalculateCommand}"
                      HorizontalAlignment="Stretch"
                      Margin="0,8,0,0"
                      Padding="14,10"
                      FontWeight="Bold" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Center panel -->
      <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
        <Grid RowDefinitions="Auto,Auto,*">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="4">
              <TextBlock Text="Последовательность постановки" FontSize="20" FontWeight="Bold" />
              <TextBlock Text="Собирается сверху вниз: буй → соединители → линия → приборы → якорь"
                         FontSize="12"
                         Foreground="#697386" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Button Content="+ линия" Command="{Binding AddLineCommand}" />
              <Button Content="+ соединитель" Command="{Binding AddConnectorCommand}" />
              <Button Content="+ прибор" Command="{Binding AddPayloadCommand}" />
            </StackPanel>
          </Grid>

          <Border Grid.Row="1" Background="#F7F9FC" CornerRadius="12" Padding="12" Margin="0,14,0,12">
            <TextBlock Text="Подсказка: поле Kind сейчас принимает Line, Connector или Payload. В следующих версиях заменим это на нормальный выпадающий список."
                       FontSize="12"
                       Foreground="#697386"
                       TextWrapping="Wrap" />
          </Border>

          <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding AssemblyItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#D7DEE9"
                          BorderThickness="1"
                          Background="#FBFCFE"
                          CornerRadius="14"
                          Padding="14"
                          Margin="0,0,0,10">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="12" RowSpacing="10">
                      <Border Width="34" Height="34" CornerRadius="17" Background="#E9EFFA" VerticalAlignment="Top">
                        <TextBlock Text="●" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#315B9A" />
                      </Border>

                      <Grid Grid.Column="1" ColumnDefinitions="*,120" ColumnSpacing="10">
                        <StackPanel Spacing="4">
                          <TextBox Text="{Binding Title}" Watermark="Название элемента" FontWeight="Bold" />
                          <CheckBox IsChecked="{Binding IsEnabled}" Content="Учитывать в расчёте" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                          <TextBlock Text="Тип" FontSize="12" Foreground="#697386" />
                          <TextBox Text="{Binding Kind}" Watermark="Line" />
                        </StackPanel>
                      </Grid>

                      <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <StackPanel Spacing="4">
                          <TextBlock Text="Линия preset" FontSize="12" Foreground="#697386" />
                          <TextBox Text="{Binding RopePresetId}" Watermark="polyester_20" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                          <TextBlock Text="Соединитель preset" FontSize="12" Foreground="#697386" />
                          <TextBox Text="{Binding ConnectorPresetId}" Watermark="shackle_55" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="4">
                          <TextBlock Text="Длина / кол-во" FontSize="12" Foreground="#697386" />
                          <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                            <TextBox Text="{Binding LengthM}" Watermark="м" />
                            <TextBox Grid.Column="1" Text="{Binding Count}" Watermark="шт." />
                          </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="4">
                          <TextBlock Text="Прибор" FontSize="12" Foreground="#697386" />
                          <TextBox Text="{Binding PayloadWeightAirKg}" Watermark="масса, кг" />
                        </StackPanel>
                      </Grid>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Right panel -->
      <Grid Grid.Column="2" RowDefinitions="260,*" RowSpacing="16">
        <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Spacing="4">
              <TextBlock Text="Результат" FontSize="20" FontWeight="Bold" />
              <TextBlock Text="Ключевые показатели после расчёта" FontSize="12" Foreground="#697386" />
            </StackPanel>

            <TextBox Grid.Row="1"
                     Text="{Binding ResultText}"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     Background="#F7F9FC"
                     BorderThickness="0"
                     FontSize="14"
                     TextWrapping="Wrap"
                     Margin="0,12,0,0" />
          </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Spacing="4">
              <TextBlock Text="Отчёт" FontSize="20" FontWeight="Bold" />
              <TextBlock Text="Markdown-текст для копирования или будущего экспорта" FontSize="12" Foreground="#697386" />
            </StackPanel>

            <TextBox Grid.Row="1"
                     Text="{Binding ReportText}"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     Background="#F7F9FC"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,12,0,0" />
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
