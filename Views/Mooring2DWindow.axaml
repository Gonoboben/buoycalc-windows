<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BuoyCalc.Windows.Views.Mooring2DWindow"
        Width="780"
        Height="880"
        MinWidth="640"
        MinHeight="660"
        Background="#F3F6FA"
        Title="2D-схема постановки v0.16">

  <Grid RowDefinitions="Auto,*,Auto" Margin="18" RowSpacing="14">
    <Border Background="#172033" CornerRadius="16" Padding="18">
      <StackPanel Spacing="4">
        <TextBlock Text="2D-схема постановки" FontSize="24" FontWeight="Bold" Foreground="White" />
        <TextBlock Text="Схематичный вид сбоку с инженерными параметрами: глубина, длина линии, снос и L/Depth." FontSize="13" Foreground="#C7D2E5" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
      <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
          <StackPanel Spacing="4">
            <TextBlock Text="Вид сбоку" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="Схема показывает порядок элементов и основные масштабные параметры. Геометрическая прорисовка линии будет уточняться дальше." FontSize="12" Foreground="#697386" TextWrapping="Wrap" />
          </StackPanel>
          <Border Grid.Column="1" Background="#E9EFFA" CornerRadius="12" Padding="12,8" VerticalAlignment="Top">
            <TextBlock Text="v0.16 scaled 2D" FontSize="12" Foreground="#263653" FontWeight="Bold" />
          </Border>
        </Grid>

        <Border Grid.Row="1" Background="#F7F9FC" BorderBrush="#D7DEE9" BorderThickness="1" CornerRadius="14" Padding="12">
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
            <Border Background="White" CornerRadius="10" Padding="10"><TextBlock Text="{Binding VisualizationDepthText}" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" /></Border>
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="10"><TextBlock Text="{Binding VisualizationLineLengthText}" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" /></Border>
            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10"><TextBlock Text="{Binding VisualizationOffsetText}" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" /></Border>
            <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="10" Padding="10"><TextBlock Text="{Binding VisualizationSlackRatioText}" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" /></Border>
            <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FFF7E6" BorderBrush="#E6C36A" BorderThickness="1" CornerRadius="10" Padding="10"><TextBlock Text="{Binding VisualizationStatusText}" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" /></Border>
          </Grid>
        </Border>

        <Border Grid.Row="2" Background="#F7F9FC" BorderBrush="#D7DEE9" BorderThickness="1" CornerRadius="16" Padding="14">
          <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
            <Border Background="#DCEBFF" BorderBrush="#A7C7EE" BorderThickness="1" CornerRadius="12" Padding="12">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                  <TextBlock Text="Поверхность воды" FontSize="13" FontWeight="Bold" Foreground="#24466D" />
                  <TextBlock Text="Буй находится в верхней части схемы" FontSize="11" Foreground="#697386" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="~~~~~~~" FontSize="18" Foreground="#315B9A" VerticalAlignment="Center" />
              </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <Grid ColumnDefinitions="110,*,110">
                <Border Grid.Column="0" Background="#EEF5FF" CornerRadius="12" Padding="10" VerticalAlignment="Stretch">
                  <StackPanel Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Глубина" FontSize="13" FontWeight="Bold" Foreground="#315B9A" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding VisualizationDepthText}" FontSize="11" Foreground="#697386" HorizontalAlignment="Center" TextWrapping="Wrap" />
                    <TextBlock Text="↓" FontSize="24" Foreground="#315B9A" HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" BorderBrush="#D7DEE9" BorderThickness="1" CornerRadius="14" Padding="16" Margin="10,0">
                  <ItemsControl ItemsSource="{Binding SequenceDiagramLines}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="#F7F9FC" BorderBrush="#D7DEE9" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                          <TextBlock Text="{Binding}" FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>

                <Border Grid.Column="2" Background="#EEF5FF" CornerRadius="12" Padding="10" VerticalAlignment="Stretch">
                  <StackPanel Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Снос" FontSize="13" FontWeight="Bold" Foreground="#315B9A" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding VisualizationOffsetText}" FontSize="11" Foreground="#697386" HorizontalAlignment="Center" TextWrapping="Wrap" />
                    <TextBlock Text="→" FontSize="24" Foreground="#315B9A" HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>
              </Grid>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#E7DED3" BorderBrush="#C9B8A8" BorderThickness="1" CornerRadius="12" Padding="12">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                  <TextBlock Text="Дно / грунт" FontSize="13" FontWeight="Bold" Foreground="#5C4634" />
                  <TextBlock Text="Якорь находится в нижней части схемы" FontSize="11" Foreground="#697386" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="▰▰▰" FontSize="18" Foreground="#5C4634" VerticalAlignment="Center" />
              </Grid>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="14" BoxShadow="0 2 12 #18000000">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <TextBlock Text="Следующий этап: прорисовать линию геометрически по глубине, длине линии, сносу и положению приборов." FontSize="12" Foreground="#697386" TextWrapping="Wrap" VerticalAlignment="Center" />
        <Button Grid.Column="1" Content="Закрыть" Click="CloseButton_Click" Padding="18,10" />
      </Grid>
    </Border>
  </Grid>
</Window>
