<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BuoyCalc.Windows.Views.ElementLibraryWindow"
        Width="1080"
        Height="740"
        MinWidth="920"
        MinHeight="620"
        Background="#F3F6FA"
        Title="Библиотека элементов">

  <Grid RowDefinitions="Auto,*" Margin="18" RowSpacing="16">

    <Border Background="#172033" CornerRadius="16" Padding="18">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="Библиотека элементов" FontSize="24" FontWeight="Bold" Foreground="White" />
          <TextBlock Text="Создание, редактирование и удаление элементов вынесены из главного окна проекта"
                     FontSize="13"
                     Foreground="#C7D2E5" />
        </StackPanel>
        <Border Grid.Column="1" Background="#263653" CornerRadius="12" Padding="12,8" VerticalAlignment="Center">
          <TextBlock Text="Буи · Линии · Соединители · Якоря" Foreground="#C7D2E5" FontSize="13" />
        </Border>
      </Grid>
    </Border>

    <TabControl Grid.Row="1">

      <TabItem Header="Буи">
        <Grid ColumnDefinitions="340,*" ColumnSpacing="16" Margin="0,12,0,0">
          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*">
              <StackPanel Spacing="4">
                <TextBlock Text="Буи" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Встроенные и пользовательские элементы" FontSize="12" Foreground="#697386" />
              </StackPanel>
              <ListBox Grid.Row="1" ItemsSource="{Binding Buoys}" SelectedItem="{Binding SelectedBuoy}" Margin="0,12,0,0" />
            </Grid>
          </Border>

          <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
              <TextBlock Text="Редактор буя" FontSize="20" FontWeight="Bold" />
              <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="12">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Название" FontSize="12" Foreground="#697386" />
                    <TextBox Text="{Binding BuoyName}" />
                  </StackPanel>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                    <StackPanel Spacing="4"><TextBlock Text="Объём, м³" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding BuoyVolume}" /></StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="Масса, кг" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding BuoyWeight}" /></StackPanel>
                    <StackPanel Grid.Row="1" Spacing="4"><TextBlock Text="Площадь, м²" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding BuoyArea}" /></StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4"><TextBlock Text="Cd" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding BuoyCd}" /></StackPanel>
                  </Grid>
                  <StackPanel Spacing="4"><TextBlock Text="Заметка / источник" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding BuoyNote}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" /></StackPanel>
                  <Border Background="#F7F9FC" CornerRadius="12" Padding="12"><TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#697386" TextWrapping="Wrap" /></Border>
                </StackPanel>
              </ScrollViewer>
              <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Content="Новый буй" Command="{Binding NewBuoyCommand}" />
                <Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveBuoyCommand}" />
                <Button Grid.Column="2" Content="Удалить" Command="{Binding DeleteBuoyCommand}" />
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Линии">
        <Grid ColumnDefinitions="340,*" ColumnSpacing="16" Margin="0,12,0,0">
          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*">
              <StackPanel Spacing="4"><TextBlock Text="Линии / буйрепы" FontSize="20" FontWeight="Bold" /><TextBlock Text="Канаты, цепи и тросы" FontSize="12" Foreground="#697386" /></StackPanel>
              <ListBox Grid.Row="1" ItemsSource="{Binding Ropes}" SelectedItem="{Binding SelectedRope}" Margin="0,12,0,0" />
            </Grid>
          </Border>
          <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
              <TextBlock Text="Редактор линии" FontSize="20" FontWeight="Bold" />
              <ScrollViewer Grid.Row="1"><StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12"><StackPanel Spacing="4"><TextBlock Text="Название" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding RopeName}" /></StackPanel><StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="Материал" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding RopeMaterial}" /></StackPanel></Grid>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10"><StackPanel Spacing="4"><TextBlock Text="Диаметр, мм" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding RopeDiameter}" /></StackPanel><StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="MBL, кН" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding RopeBreakingLoad}" /></StackPanel><StackPanel Grid.Row="1" Spacing="4"><TextBlock Text="Вес в воде, кг/м" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding RopeWeightWater}" /></StackPanel><StackPanel Grid.Row="1" Grid.Column="1" Spacing="4"><TextBlock Text="Cd" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding RopeCd}" /></StackPanel></Grid>
                <StackPanel Spacing="4"><TextBlock Text="Заметка / источник" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding RopeNote}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" /></StackPanel>
                <Border Background="#F7F9FC" CornerRadius="12" Padding="12"><TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#697386" TextWrapping="Wrap" /></Border>
              </StackPanel></ScrollViewer>
              <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10"><Button Content="Новая линия" Command="{Binding NewRopeCommand}" /><Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveRopeCommand}" /><Button Grid.Column="2" Content="Удалить" Command="{Binding DeleteRopeCommand}" /></Grid>
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Соединители">
        <Grid ColumnDefinitions="340,*" ColumnSpacing="16" Margin="0,12,0,0">
          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*"><StackPanel Spacing="4"><TextBlock Text="Соединители" FontSize="20" FontWeight="Bold" /><TextBlock Text="Скобы, вертлюги, релизы" FontSize="12" Foreground="#697386" /></StackPanel><ListBox Grid.Row="1" ItemsSource="{Binding Connectors}" SelectedItem="{Binding SelectedConnector}" Margin="0,12,0,0" /></Grid>
          </Border>
          <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12"><TextBlock Text="Редактор соединителя" FontSize="20" FontWeight="Bold" /><ScrollViewer Grid.Row="1"><StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,*" ColumnSpacing="12"><StackPanel Spacing="4"><TextBlock Text="Название" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding ConnectorName}" /></StackPanel><StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="Тип" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding ConnectorType}" /></StackPanel></Grid>
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10"><StackPanel Spacing="4"><TextBlock Text="Масса, кг" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding ConnectorWeightAir}" /></StackPanel><StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="Объём, м³" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding ConnectorVolume}" /></StackPanel><StackPanel Grid.Row="1" Spacing="4"><TextBlock Text="MBL, кН" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding ConnectorBreakingLoad}" /></StackPanel><StackPanel Grid.Row="1" Grid.Column="1" Spacing="4"><TextBlock Text="Площадь, м²" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding ConnectorArea}" /></StackPanel><StackPanel Grid.Row="2" Spacing="4"><TextBlock Text="Cd" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding ConnectorCd}" /></StackPanel></Grid>
              <StackPanel Spacing="4"><TextBlock Text="Заметка / источник" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding ConnectorNote}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" /></StackPanel><Border Background="#F7F9FC" CornerRadius="12" Padding="12"><TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#697386" TextWrapping="Wrap" /></Border>
            </StackPanel></ScrollViewer><Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10"><Button Content="Новый соединитель" Command="{Binding NewConnectorCommand}" /><Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveConnectorCommand}" /><Button Grid.Column="2" Content="Удалить" Command="{Binding DeleteConnectorCommand}" /></Grid></Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Якоря">
        <Grid ColumnDefinitions="340,*" ColumnSpacing="16" Margin="0,12,0,0">
          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*"><StackPanel Spacing="4"><TextBlock Text="Якоря" FontSize="20" FontWeight="Bold" /><TextBlock Text="Грузы, грибовидные и плитные якоря" FontSize="12" Foreground="#697386" /></StackPanel><ListBox Grid.Row="1" ItemsSource="{Binding Anchors}" SelectedItem="{Binding SelectedAnchor}" Margin="0,12,0,0" /></Grid>
          </Border>
          <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12"><TextBlock Text="Редактор якоря" FontSize="20" FontWeight="Bold" /><ScrollViewer Grid.Row="1"><StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,*" ColumnSpacing="12"><StackPanel Spacing="4"><TextBlock Text="Название" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding AnchorName}" /></StackPanel><StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="Тип" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding AnchorType}" /></StackPanel></Grid>
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10"><StackPanel Spacing="4"><TextBlock Text="Материал" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding AnchorMaterial}" /></StackPanel><StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="Масса, кг" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding AnchorWeightAir}" /></StackPanel><StackPanel Grid.Row="1" Spacing="4"><TextBlock Text="Объём, м³" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding AnchorVolume}" /></StackPanel><StackPanel Grid.Row="1" Grid.Column="1" Spacing="4"><TextBlock Text="Коэф. удержания" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding AnchorHoldingCoefficient}" /></StackPanel></Grid>
              <StackPanel Spacing="4"><TextBlock Text="Заметка / источник" FontSize="12" Foreground="#697386" /><TextBox Text="{Binding AnchorNote}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" /></StackPanel><Border Background="#F7F9FC" CornerRadius="12" Padding="12"><TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#697386" TextWrapping="Wrap" /></Border>
            </StackPanel></ScrollViewer><Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10"><Button Content="Новый якорь" Command="{Binding NewAnchorCommand}" /><Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveAnchorCommand}" /><Button Grid.Column="2" Content="Удалить" Command="{Binding DeleteAnchorCommand}" /></Grid></Grid>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
