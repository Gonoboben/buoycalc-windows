<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BuoyCalc.Windows.Views.ElementLibraryWindow"
        Width="1040"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        Background="#F3F6FA"
        Title="Библиотека элементов">

  <Grid RowDefinitions="Auto,*" Margin="18" RowSpacing="16">

    <Border Background="#172033" CornerRadius="16" Padding="18">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="Библиотека элементов" FontSize="24" FontWeight="Bold" Foreground="White" />
          <TextBlock Text="Создание, редактирование и удаление элементов вынесены из главного окна проекта"
                     FontSize="13"
                     Foreground="#C7D2E5" />
        </StackPanel>

        <Border Grid.Column="1" Background="#263653" CornerRadius="12" Padding="12,8" VerticalAlignment="Center">
          <TextBlock Text="Буи · Линии" Foreground="#C7D2E5" FontSize="13" />
        </Border>
      </Grid>
    </Border>

    <TabControl Grid.Row="1">
      <TabItem Header="Буи">
        <Grid ColumnDefinitions="340,*" ColumnSpacing="16" Margin="0,12,0,0">

          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*">
              <StackPanel Spacing="4">
                <TextBlock Text="Буи" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Встроенные и пользовательские элементы" FontSize="12" Foreground="#697386" />
              </StackPanel>

              <ListBox Grid.Row="1"
                       ItemsSource="{Binding Buoys}"
                       SelectedItem="{Binding SelectedBuoy}"
                       Margin="0,12,0,0" />
            </Grid>
          </Border>

          <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="Редактор буя" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Встроенный буй можно использовать как основу, но сохраняется он как пользовательский элемент"
                           FontSize="12"
                           Foreground="#697386" />
              </StackPanel>

              <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="12">

                  <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="Название" FontSize="12" Foreground="#697386" />
                      <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Короткое понятное имя буя. Оно будет отображаться в списке, главном окне и отчёте." />
                    </StackPanel>
                    <TextBox Text="{Binding BuoyName}" Watermark="Название буя" />
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                    <StackPanel Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Объём, м³" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Вытесненный объём буя. Используется для расчёта полной плавучести: объём × плотность воды. Берётся из паспорта буя или считается по геометрии." />
                      </StackPanel>
                      <TextBox Text="{Binding BuoyVolume}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Масса, кг" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Масса буя в воздухе. Обычно берётся из паспорта производителя или измеряется перед постановкой." />
                      </StackPanel>
                      <TextBox Text="{Binding BuoyWeight}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Проецируемая площадь, м²" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Площадь силуэта буя, перпендикулярная потоку. Используется в расчёте сопротивления течению." />
                      </StackPanel>
                      <TextBox Text="{Binding BuoyArea}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Cd" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Коэффициент сопротивления формы. Берётся из паспорта, справочника, испытаний или задаётся инженерной оценкой для формы буя." />
                      </StackPanel>
                      <TextBox Text="{Binding BuoyCd}" />
                    </StackPanel>
                  </Grid>

                  <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="Заметка / источник" FontSize="12" Foreground="#697386" />
                      <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Укажите источник данных: паспорт производителя, расчёт по геометрии, измерение, справочник или временный тестовый пресет." />
                    </StackPanel>
                    <TextBox Text="{Binding BuoyNote}"
                             Watermark="Например: паспорт производителя, расчёт по геометрии, тестовый пресет"
                             AcceptsReturn="True"
                             MinHeight="90"
                             TextWrapping="Wrap" />
                  </StackPanel>

                  <Border Background="#F7F9FC" CornerRadius="12" Padding="12">
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#697386" TextWrapping="Wrap" />
                  </Border>
                </StackPanel>
              </ScrollViewer>

              <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Content="Новый буй" Command="{Binding NewBuoyCommand}" />
                <Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveBuoyCommand}" />
                <Button Grid.Column="2" Content="Удалить" Command="{Binding DeleteBuoyCommand}" />
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Линии">
        <Grid ColumnDefinitions="340,*" ColumnSpacing="16" Margin="0,12,0,0">

          <Border Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*">
              <StackPanel Spacing="4">
                <TextBlock Text="Линии / буйрепы" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Канаты, цепи и тросы" FontSize="12" Foreground="#697386" />
              </StackPanel>

              <ListBox Grid.Row="1"
                       ItemsSource="{Binding Ropes}"
                       SelectedItem="{Binding SelectedRope}"
                       Margin="0,12,0,0" />
            </Grid>
          </Border>

          <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16" BoxShadow="0 2 12 #18000000">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="Редактор линии" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Встроенную линию можно использовать как основу, но сохраняется она как пользовательский элемент"
                           FontSize="12"
                           Foreground="#697386" />
              </StackPanel>

              <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="12">

                  <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Название" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Короткое имя линии. Оно будет видно в библиотеке и в выпадающем списке последовательности." />
                      </StackPanel>
                      <TextBox Text="{Binding RopeName}" Watermark="Например: Polyester 20 mm" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Материал" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Материал линии: полиэстер, нейлон, стальная цепь, стальной трос и т.д. Пока используется в отчёте и для понимания пресета." />
                      </StackPanel>
                      <TextBox Text="{Binding RopeMaterial}" Watermark="Материал" />
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                    <StackPanel Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Диаметр, мм" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Номинальный диаметр каната, цепи или троса. Используется для грубой оценки проецируемой площади линии в потоке." />
                      </StackPanel>
                      <TextBox Text="{Binding RopeDiameter}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="MBL, кН" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Minimum Breaking Load — минимальная разрывная нагрузка. Берётся из паспорта производителя. В расчёте используется для проверки запаса по натяжению." />
                      </StackPanel>
                      <TextBox Text="{Binding RopeBreakingLoad}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Вес в воде, кг/м" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Погонный вес линии в воде. Для синтетики может быть малым или близким к нулю, для цепи заметно выше. Берётся из паспорта или рассчитывается через массу и вытеснение." />
                      </StackPanel>
                      <TextBox Text="{Binding RopeWeightWater}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Cd" FontSize="12" Foreground="#697386" />
                        <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Коэффициент сопротивления линии в потоке. Для предварительного расчёта можно начинать с 1.1–1.2 для круглых канатов/тросов." />
                      </StackPanel>
                      <TextBox Text="{Binding RopeCd}" />
                    </StackPanel>
                  </Grid>

                  <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="Заметка / источник" FontSize="12" Foreground="#697386" />
                      <TextBlock Text="?" FontSize="12" Foreground="#315B9A" ToolTip.Tip="Укажите источник данных: паспорт каната/цепи, каталог производителя, расчёт или временный тестовый пресет." />
                    </StackPanel>
                    <TextBox Text="{Binding RopeNote}"
                             Watermark="Например: паспорт производителя, таблица MBL, тестовый пресет"
                             AcceptsReturn="True"
                             MinHeight="90"
                             TextWrapping="Wrap" />
                  </StackPanel>

                  <Border Background="#F7F9FC" CornerRadius="12" Padding="12">
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#697386" TextWrapping="Wrap" />
                  </Border>
                </StackPanel>
              </ScrollViewer>

              <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Content="Новая линия" Command="{Binding NewRopeCommand}" />
                <Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveRopeCommand}" />
                <Button Grid.Column="2" Content="Удалить" Command="{Binding DeleteRopeCommand}" />
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
